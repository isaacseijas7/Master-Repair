{
  "name": "master-repair-api",
  "version": "1.0.0",
  "description": "Sistema ERP de Gestión de Inventario - Máster Repair",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "seed": "ts-node src/seeders/index.ts",
    "seed:users": "ts-node src/seeders/user.seeder.ts",
    "seed:categories": "ts-node src/seeders/category.seeder.ts",
    "seed:products": "ts-node src/seeders/product.seeder.ts",
    "seed:orders": "ts-node src/seeders/order.seeder.ts",
    "db:reset": "npm run seed"
  },
  "keywords": [
    "erp",
    "inventory",
    "fastify",
    "mongodb"
  ],
  "author": "Máster Repair",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.1",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.11",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint": "^8.57.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
